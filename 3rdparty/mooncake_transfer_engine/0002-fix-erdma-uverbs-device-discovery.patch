+                 device_name);
+
+        DIR *dir = opendir(verbs_dir);
+        if (dir != NULL) {
+            struct dirent *entry = nullptr;
+            bool found = false;
+            while ((entry = readdir(dir)) != NULL) {
+                if (entry->d_name[0] == '.') {
+                    continue;
+                }
+
+                snprintf(device_path,
+                         sizeof(device_path),
+                         "/dev/infiniband/%s",
+                         entry->d_name);
+                if (stat(device_path, &st) == 0 && S_ISCHR(st.st_mode)) {
+                    found = true;
+                    break;
+                }
+            }
+            closedir(dir);
+            if (!found) {
+                device_path[0] = '\0';
+            }
+        } else {
+            device_path[0] = '\0';
+        }
+    }
+
+    if (device_path[0] == '\0') {
+        LOG(WARNING) << "Device " << device_name
+                     << " character device under /dev/infiniband was not found";
+        return false;
+    }
 
     if (stat(device_path, &st) != 0) {
